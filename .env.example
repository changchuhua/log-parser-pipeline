OLLAMA_API_BASE=http://<url>:<port>/api
OLLAMA_MODEL=qwen #qwen, gemma or deepseek
OLLAMA_TIMEOUT=90
USE_CACHE=false
WRITE_CACHE=true
LLM_DEBUG=false

# Component 2 (SO Extractor) and Component 5 (Deployer) — Security Onion connection details
TAILSCALE_NODE= # Tailscale hostname/IP of the Security Onion box (DLQ extraction, SFTP deploy)
TS_USER= # SSH user for the Tailscale connection (defaults to "admin" if unset)
TS_PASS= # SSH password for the Tailscale connection. Leave blank for Tailscale SSH or SSH-key/agent auth
SO_IP= # Security Onion Elasticsearch host
SO_USER= # Elasticsearch basic-auth username (unrelated to the SSH login above)
SO_PASS= # Elasticsearch basic-auth password (unrelated to the SSH login above)
